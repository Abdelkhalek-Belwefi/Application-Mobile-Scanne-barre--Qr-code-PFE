<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Image de fond (gradient) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_gradient"
        android:scaleType="centerCrop"
        android:contentDescription="@string/app_name" />

    <!-- Superposition sombre -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.15" />

        <ImageView
            android:id="@+id/imgLogoTop"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/warehouse_logo"
            android:background="@drawable/bg_logo_circle"
            android:padding="12dp"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WAREHOUSE_PFE"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.1"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scanner  : Document Code Barre / Qr Code /DataMatrix"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.3" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#33000000">

            <TextView
                android:id="@+id/txtStatus"
                android:text="📱 Scanner prêt"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnScan"
            android:text="🔍 SCANNER_CODE"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_gradient"
            android:elevation="4dp"
            android:letterSpacing="0.05" />

        <Button
            android:id="@+id/btnScanDocument"
            android:text="📄 SCANNER DOCUMENT"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_secondary"
            android:elevation="4dp"
            android:letterSpacing="0.05" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.35" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="créé par Abdelkhalek Belwefi _ Aymen Achour Chelly"
            android:textSize="11sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:padding="8dp" />

    </LinearLayout>
</FrameLayout>