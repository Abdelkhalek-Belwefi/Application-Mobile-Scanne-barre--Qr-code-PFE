<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Image de fond -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/abdou_aymen"
        android:scaleType="centerCrop"
        android:contentDescription="@string/app_name" />

    <!-- Superposition sombre pour lisibilité -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" />

    <!-- Conteneur principal vertical -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logo en haut -->
        <ImageView
            android:id="@+id/imgLogoTop"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/warehouse_logo"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/app_name" />

        <!-- Zone centrale (statut + bouton) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginVertical="16dp">

            <!-- Votre TextView d'origine (inchangé) -->
            <TextView
                android:id="@+id/txtStatus"
                android:text="Scanner prêt"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Bouton Scan plus petit et arrondi (ID inchangé) -->
            <Button
                android:id="@+id/btnScan"
                android:text="Scanner"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_small_rounded"
                android:elevation="2dp" />

        </LinearLayout>

        <!-- Pied de page : créateurs -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="créé par Abdelkhalek Belwefi et Aymen Achour Chelly"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:padding="8dp" />

    </LinearLayout>

</FrameLayout>